# Copie este arquivo para ".env.local" e preencha com os dados do seu projeto Supabase.
# Onde encontrar: painel do Supabase > seu projeto > Project Settings > API

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-public-aqui

# NUNCA coloque a "service_role key" aqui — ela nunca deve ir para o frontend.
